# Admin app URL
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Console app URL (used for public brand/product API calls)
CONSOLE_URL=http://localhost:3003

# PostgreSQL — buyer database (auth, wishlists, preferences)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opend2c?sslmode=disable

# BetterAuth — https://www.better-auth.com/docs/installation
BETTER_AUTH_URL=http://localhost:3002
BETTER_AUTH_SECRET=

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Discord webhook for feedback notifications
DISCORD_FEEDBACK_WEBHOOK_URL=
