# Console auth + scraper persistence
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opend2c?sslmode=disable
BETTER_AUTH_URL=http://localhost:3003
BETTER_AUTH_SECRET=

# Crawler worker — set WORKER_SECRET to the same value as the crawler's WORKER_SECRET env var.
# In production: WORKER_URL=https://crawler.opend2c.com
WORKER_URL=http://localhost:8080
WORKER_SECRET=change-me-in-production
