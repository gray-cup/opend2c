# PostgreSQL connection string for the crawler's own job/product DB
DATABASE_URL=postgres://user:password@host:5432/crawler_db

# Shared secret between the console and this worker.
# Generate with: openssl rand -hex 32
# Must match WORKER_SECRET in the console's env.
WORKER_SECRET=change-me-in-production

# Comma-separated list of allowed CORS origins.
# Set to the console's Vercel URL in production.
# Leave empty to allow all origins (dev only).
ALLOWED_ORIGINS=https://console.opend2c.com,http://localhost:3003

# Port to listen on (default: 8080)
PORT=8080
